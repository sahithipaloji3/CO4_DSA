public class BellmanFordDemo {

    static class Edge {

        int src,dest,weight;

        Edge(int s,int d,int w) {
            src=s;
            dest=d;
            weight=w;
        }
    }

    public static void main(String[] args) {

        int V = 5;

        Edge edges[] = {

                new Edge(0,1,4),
                new Edge(0,2,1),
                new Edge(2,1,2),
                new Edge(1,3,1),
                new Edge(2,3,5),
                new Edge(3,4,3)
        };

        int dist[] = new int[V];

        for(int i=0;i<V;i++)
            dist[i] = Integer.MAX_VALUE;

        dist[0] = 0;

        for(int i=1;i<V;i++) {

            for(Edge e : edges) {

                if(dist[e.src] != Integer.MAX_VALUE
                        &&
                        dist[e.src] + e.weight
                                < dist[e.dest]) {

                    dist[e.dest] =
                            dist[e.src]
                                    + e.weight;
                }
            }
        }

        System.out.println(
                "Vertex\tDistance");

        for(int i=0;i<V;i++) {

            System.out.println(
                    i + "\t" + dist[i]);
        }
    }
}
